{
    "compilerOptions": {
        "baseUrl": ".",
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "Node",
        "jsx": "react-jsx",
        "allowJs": true,
        "checkJs": false,
        "allowSyntheticDefaultImports": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "paths": {
            "@/*": [
                "resources/js/*"
            ]
        }
    },
    "include": [
        "resources/js/**/*",
        "resources/**/*.js",
        "resources/**/*.jsx",
        "vite.config.js"
    ],
    "exclude": [
        "node_modules",
        "vendor",
        "public/build"
    ]
}